# Chexit API — REQUIRED on Vercel: full https base URL of your FastAPI (no /predict suffix).
# Vercel rewrites every path to index.html; without this, POST /api/predict returns 405.
# Local dev: leave EMPTY — /api/predict is proxied to http://127.0.0.1:8000 (npm run dev or vite preview on localhost).
# If you use vite preview on a LAN/tunnel host (not localhost), set VITE_USE_RELATIVE_API=1 or set VITE_CHEXIT_API_URL.
# VITE_CHEXIT_API_URL=
# VITE_USE_RELATIVE_API=

# Set to 1 to run `npm run test:integration` (Firestore scratch doc; add rules for __vitest_connectivity).
VITE_RUN_FIREBASE_INTEGRATION=

# Firebase (optional – app uses fallbacks if unset)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
